#define ECHO_PIN 17
#define TRIG_PIN 16


const int led = 27;

bool mqttStatus = 0;

const char* ssid = "Wokwi-GUEST"; // REDE WIFi
const char* password = ""; // SENHA WIFi

// MQTT Broker
const char *mqtt_broker = "broker.hivemq.com";//Host do broket
const char* topic[] = {
  "mirella"
};//Topico a ser subscrito e publicado
